# ============================================================================
# Sophia Frontend Environment Variables
# ============================================================================
# Copy this file to .env.local and fill in your values
# cp .env.example .env.local

# ============================================================================
# REQUIRED - Backend API
# ============================================================================

# Backend API URL (FastAPI server)
# Local development: http://localhost:8000
# Production: https://your-backend.render.com
NEXT_PUBLIC_API_URL=http://localhost:8000

# WebSocket URL for voice/streaming (usually same as API URL)
NEXT_PUBLIC_WS_URL=ws://localhost:8000

# Alternative backend URL (for server-side API calls on Vercel/Render)
# Use this if your backend is on a different domain than the frontend
RENDER_BACKEND_URL=

# ============================================================================
# REQUIRED - Supabase Authentication
# ============================================================================

# Supabase Project URL
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co

# Supabase Anonymous Key (safe for frontend)
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJ...

# ============================================================================
# OPTIONAL - Feature Flags
# ============================================================================

# Enable/disable voice features
NEXT_PUBLIC_ENABLE_VOICE=true

# Enable/disable text chat
NEXT_PUBLIC_ENABLE_TEXT=true

# Enable/disable emotion detection UI
NEXT_PUBLIC_ENABLE_EMOTIONS=true

# ============================================================================
# OPTIONAL - Development/Debug
# ============================================================================

# Force mock bootstrap data (for offline development)
# Set to 'true' only if you don't have backend running
USE_MOCK_BOOTSTRAP=false

# Enable verbose logging
NEXT_PUBLIC_DEBUG=false

# ============================================================================
# OPTIONAL - Capacitor Mobile Build
# ============================================================================

# Set to 'true' when building for Capacitor (mobile apps)
CAPACITOR_BUILD=false
