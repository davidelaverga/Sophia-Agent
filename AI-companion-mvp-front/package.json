{
  "name": "sophia-frontend",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "dev:mobile": "dotenv -e .env.dev -- next dev -H 0.0.0.0",
    "build": "next build",
    "build:dev": "dotenv -e .env.dev -- next build",
    "start": "next start",
    "lint": "next lint",
    "type-check": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:ui": "vitest --ui",
    "test:coverage": "vitest run --coverage",
    "test:e2e": "playwright test",
    "capture:session": "node scripts/capture-live-session.mjs",
    "benchmark:voice": "node scripts/run-voice-benchmark.mjs",
    "test:e2e:memory": "playwright test tests/e2e/memory-highlights.spec.ts",
    "test:e2e:ci": "playwright test tests/e2e/memory-highlights.spec.ts --project=chromium",
    "test:guardrails:p4": "npm run check:logs:global && npm run check:sophia:surface-boundary && npm run type-check && vitest run src/__tests__/hooks/voice stream-protocol stream-transformers chat-request useSessionExtractedHooks useSessionRetryHandlers useSessionVoiceCommandSystem src/__tests__/architecture/runtime-ownership-contract.test.ts",
    "check:sophia:surface-boundary": "node ../scripts/check-sophia-surface-boundary.js",
    "check:logs:p3": "node scripts/check-p3-console-guardrail.js",
    "check:logs:global": "node scripts/check-global-console-guardrail.js",
    "smoke:stream-auth": "pwsh -File scripts/smoke-stream-auth.ps1",
    "cap:sync": "npx cap sync",
    "cap:android": "npx cap open android",
    "cap:ios": "npx cap open ios",
    "cap:android:run": "npx cap run android",
    "cap:ios:run": "npx cap run ios",
    "cap:live": "echo 'Update capacitor.config.ts with your local IP, then run: npm run dev:mobile'"
  },
  "dependencies": {
    "@ai-sdk/react": "^3.0.37",
    "@capacitor/android": "^8.0.0",
    "@capacitor/cli": "^8.0.0",
    "@capacitor/core": "^8.0.0",
    "@capacitor/haptics": "^8.0.0",
    "@capacitor/ios": "^8.0.0",
    "@capacitor/splash-screen": "^8.0.0",
    "@capacitor/status-bar": "^8.0.0",
    "@heroicons/react": "^2.2.0",
    "@sentry/nextjs": "^10.27.0",
    "@stream-io/video-react-sdk": "^1.34.1",
    "@supabase/auth-helpers-nextjs": "^0.10.0",
    "@supabase/auth-helpers-react": "^0.5.0",
    "@supabase/ssr": "^0.8.0",
    "@supabase/supabase-js": "^2.57.4",
    "ai": "^6.0.35",
    "autoprefixer": "^10.4.16",
    "clsx": "^2.0.0",
    "lucide-react": "^0.294.0",
    "next": "14.2.35",
    "postcss": "^8.4.32",
    "react": "18.3.0",
    "react-dom": "18.3.0",
    "tailwind-merge": "^2.1.0",
    "zod": "^4.3.6",
    "zustand": "^4.4.7"
  },
  "devDependencies": {
    "@playwright/test": "^1.58.2",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/node": "20.10.5",
    "@types/react": "18.3.27",
    "@types/react-dom": "18.3.7",
    "@vitejs/plugin-react": "^4.7.0",
    "autoprefixer": "^10.4.16",
    "baseline-browser-mapping": "^2.10.0",
    "cross-env": "^10.1.0",
    "dotenv-cli": "^11.0.0",
    "eslint": "8.56.0",
    "eslint-config-next": "14.2.35",
    "jsdom": "^27.4.0",
    "postcss": "^8.4.32",
    "tailwindcss": "^3.3.6",
    "typescript": "5.3.3",
    "vitest": "^2.1.9"
  }
}
