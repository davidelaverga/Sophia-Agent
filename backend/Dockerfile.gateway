# Sophia Gateway API
FROM python:3.12-slim

COPY --from=ghcr.io/astral-sh/uv:0.7.20 /uv /uvx /usr/local/bin/

WORKDIR /app
COPY backend ./backend
COPY skills ./skills
COPY users ./users
COPY .env* ./

RUN --mount=type=cache,target=/root/.cache/uv \
    sh -c "cd backend && uv sync"

ENV PYTHONPATH=.

CMD ["sh", "-c", "cd backend && uv run uvicorn app.gateway.app:app --host 0.0.0.0 --port ${PORT:-8001}"]
