{
  "name": "sophia-frontend",
  "version": "1.0.0",
  "private": true,
  "packageManager": "pnpm@10.26.2",
  "scripts": {
    "dev": "next dev",
    "dev:mobile": "dotenv -e .env.dev -- next dev -H 0.0.0.0",
    "auth:migrate": "dotenv -e .env -- node ./scripts/migrate-better-auth.mjs",
    "build": "next build",
    "build:dev": "dotenv -e .env.dev -- next build",
    "start": "next start",
    "lint": "eslint .",
    "lint:fix": "eslint . --ext .ts,.tsx --fix",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:ui": "vitest --ui",
    "test:coverage": "vitest run --coverage",
    "test:e2e": "playwright test",
    "test:e2e:auth": "cross-env PORT=3101 PLAYWRIGHT_TEST_BASE_URL=http://127.0.0.1:3101 PLAYWRIGHT_REUSE_EXISTING_SERVER=false BETTER_AUTH_URL=http://127.0.0.1:3101 NEXT_PUBLIC_DEV_BYPASS_AUTH=false SOPHIA_E2E_TEST_AUTH=true SOPHIA_AUTH_BACKEND_URL=http://127.0.0.1:3101 playwright test tests/e2e/auth-real-login.spec.ts --project=chromium --workers=1",
    "test:e2e:memory": "playwright test tests/e2e/memory-highlights.spec.ts",
    "test:e2e:ritual-journal": "playwright test tests/e2e/ritual-journal.spec.ts --workers=1",
    "test:e2e:voice": "playwright test tests/e2e/voice-webrtc.spec.ts --workers=1",
    "test:e2e:live": "playwright test tests/e2e/ritual-journal.spec.ts tests/e2e/voice-webrtc.spec.ts --workers=1",
    "test:e2e:ci": "playwright test tests/e2e/memory-highlights.spec.ts --project=chromium",
    "capture:session": "node scripts/capture-live-session.mjs",
    "benchmark:voice": "node scripts/run-voice-benchmark.mjs",
    "cap:sync": "npx cap sync",
    "cap:android": "npx cap open android",
    "cap:ios": "npx cap open ios",
    "cap:android:run": "npx cap run android",
    "cap:ios:run": "npx cap run ios",
    "cap:live": "echo 'Update capacitor.config.ts with your local IP, then run: pnpm dev:mobile'"
  },
  "dependencies": {
    "@ai-sdk/react": "^3.0.37",
    "@capacitor/android": "^8.0.0",
    "@capacitor/cli": "^8.0.0",
    "@capacitor/core": "^8.0.0",
    "@capacitor/haptics": "^8.0.0",
    "@capacitor/ios": "^8.0.0",
    "@capacitor/splash-screen": "^8.0.0",
    "@capacitor/status-bar": "^8.0.0",
    "@heroicons/react": "^2.2.0",
    "@sentry/nextjs": "^10.27.0",
    "@stream-io/video-react-sdk": "^1.34.1",
    "@t3-oss/env-nextjs": "^0.13.11",
    "@tailwindcss/postcss": "^4.1.0",
    "ai": "^6.0.35",
    "autoprefixer": "^10.4.16",
    "better-auth": "^1.5.6",
    "clsx": "^2.0.0",
    "lucide-react": "^0.294.0",
    "next": "^16.1.7",
    "pg": "^8.20.0",
    "postcss": "^8.4.32",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "tailwind-merge": "^2.1.0",
    "zod": "^4.3.6",
    "zustand": "^4.4.7"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3.3.5",
    "@playwright/test": "^1.58.2",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/node": "20.10.5",
    "@types/pg": "^8.20.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@vitejs/plugin-react": "^4.7.0",
    "baseline-browser-mapping": "^2.10.0",
    "cross-env": "^10.1.0",
    "dotenv-cli": "^11.0.0",
    "eslint": "^9.23.0",
    "eslint-config-next": "^15.2.3",
    "jsdom": "^27.4.0",
    "pdfjs-dist": "^5.6.205",
    "postcss": "^8.4.32",
    "prettier": "^3.5.3",
    "tailwindcss": "^4.1.0",
    "typescript": "^5.8.2",
    "typescript-eslint": "^8.58.0",
    "vitest": "^2.1.9"
  }
}
