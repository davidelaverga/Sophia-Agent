# Since the ".env" file is gitignored, you can use the ".env.example" file to
# build a new ".env" file when you clone the repo. Keep this file up-to-date
# when you add new variables to `.env`.

# This file will be committed to version control, so make sure not to have any
# secrets in it. If you are cloning this repo, create a copy of this file named
# ".env" and populate it with your secrets.

# When adding additional environment variables, the schema in "/src/env.js"
# should be updated accordingly.

# Better Auth (required)
# Generate with: openssl rand -base64 32
BETTER_AUTH_SECRET=
BETTER_AUTH_URL=http://localhost:3000

# Better Auth database (required when auth bypass is disabled)
# Better Auth in this frontend uses Postgres now, not SQLite.
# `frontend/pnpm-lock.yaml` may still mention `better-sqlite3` because Better Auth declares optional adapters.
# That lockfile entry is not evidence that the running app still depends on SQLite.
# Use your Supabase Postgres connection string here, or set DATABASE_URL instead.
# BETTER_AUTH_DATABASE_URL=postgresql://postgres:[YOUR-PASSWORD]@db.[YOUR-PROJECT].supabase.co:5432/postgres
# Hosted Postgres providers like Supabase work with the default auto mode.
BETTER_AUTH_DATABASE_SSL_MODE=auto
# Current local default keeps the auth pool constrained for Supabase/serverless-style usage.
BETTER_AUTH_DATABASE_POOL_MAX=1

# Google OAuth (required for social login)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Backend API URLs for local development
BACKEND_API_URL=http://localhost:8000
NEXT_PUBLIC_API_URL=http://localhost:8000
NEXT_PUBLIC_GATEWAY_URL=http://localhost:8001
SOPHIA_AUTH_BACKEND_URL=http://localhost:3000
SOPHIA_LANGGRAPH_BASE_URL=http://127.0.0.1:2024
NEXT_PUBLIC_LANGGRAPH_BASE_URL=http://127.0.0.1:2024

# Local OAuth mode
# Set either bypass flag to true only when you want to skip Better Auth locally.
# Preferred auth flag. This takes precedence over NEXT_PUBLIC_DEV_BYPASS_AUTH.
NEXT_PUBLIC_SOPHIA_AUTH_BYPASS=false
# Legacy fallback flag. Keep false locally unless you explicitly want bypass mode.
NEXT_PUBLIC_DEV_BYPASS_AUTH=false
NEXT_PUBLIC_SOPHIA_USER_ID=dev-user

